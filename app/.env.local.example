# x402 Protocol Configuration
# Set X402_ENABLED=true to gate API endpoints with USDC micropayments
X402_ENABLED=true
# Base Sepolia wallet address to receive USDC payments
X402_PAY_TO_ADDRESS=
# x402 facilitator URL (default: https://x402.org/facilitator)
X402_FACILITATOR_URL=https://x402.org/facilitator
# Payment network (base-sepolia for staging, base for production)
X402_NETWORK=base-sepolia

# Ethereum Sepolia RPC for reading contract state
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Relayer Configuration
# Private key of funded Sepolia wallet for gas (relayer submits txs on behalf of players)
RELAYER_PRIVATE_KEY=

# USDC entry fee in human-readable amount (for display purposes)
X402_ENTRY_FEE_USDC=0.05

# Analytics
ANALYTICS_SECRET=
